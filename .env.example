# === LLM Provider ===
# Options: "azure" (recommended for demo) | "ollama" (local fine-tuned) | "openai"
LLM_PROVIDER=azure

# === Azure OpenAI (primary for agent + fallback) ===
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# === Ollama (local fine-tuned model) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=vani-copilot

# === OpenAI (alternative) ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# === Agent ===
AGENT_ENABLED=true
CONFIDENCE_THRESHOLD=0.7

# === Embedding ===
# Base model (HuggingFace) or local fine-tuned path
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_MODEL_PATH=
EMBEDDING_DEVICE=cpu

# === Re-ranker (optional) ===
RERANKER_ENABLED=false
RERANKER_MODEL_PATH=
RERANKER_DEVICE=cpu

# === FAISS ===
FAISS_INDEX_PATH=vectorstore/faiss_index
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5

# === Database ===
DB_PATH=data/copilot.db

# === API Security ===
API_KEY=vani-copilot-dev-key

# === Server ===
HOST=0.0.0.0
PORT=8000
